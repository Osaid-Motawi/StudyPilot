{
  "name": "studypilot-backend",
  "version": "1.0.0",
  "description": "StudyPilot backend — Node.js/Express REST API (owns Firestore, verifies Firebase ID tokens, orchestrates the agent, scores MCQs).",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "lint": "eslint src tests"
  },
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "clearMocks": true
  }
}
